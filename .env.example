# ─────────────────────────────────────────────────────────────────────────────
# BracketChain Frontend — environment variables
# Copy this file to `.env.local` (gitignored) and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# REST API (indexer). Local dev: http://localhost:3001
# Production: Railway-hosted indexer URL.
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# Solana cluster the UI is talking to. One of: localnet | devnet | mainnet-beta.
# Also mirrored server-side (SOLANA_NETWORK below) for routes that need a gate.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
SOLANA_NETWORK=devnet

# Deployed BracketChain program ID on the cluster above.
NEXT_PUBLIC_PROGRAM_ID=

# Solana RPC endpoint. Use a Helius/QuickNode/etc. URL for devnet/mainnet;
# http://localhost:8899 for localnet.
NEXT_PUBLIC_RPC_URL=

# Mock USDC mint used as the default tournament collateral.
# Generated by the protocol init script (BracketChain-Programs/scripts/init-protocol.ts).
NEXT_PUBLIC_USDC_MINT=

# Phase 1 oracle wiring.
# - On localnet: enables the MockSigned provider in the UI.
# - Pubkey below is the trusted Ed25519 signer for mock attestations.
#   Private keypair lives at scripts/.oracle-keypair.json (gitignored).
NEXT_PUBLIC_MOCK_ORACLE_PUBKEY=

# ─── Game adapter API keys (server-side only — never prefix with NEXT_PUBLIC_) ──
STEAM_API_KEY=
PANDASCORE_API_KEY=
